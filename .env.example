# Which backend the MCP server uses: "demo" (default) or "imap".
MAIL_BACKEND=demo

# --- only used when MAIL_BACKEND=imap ---------------------------------------
# Use a BURNER account, never your real or work mailbox. Pick a provider that
# still allows app-password IMAP for testing -- Microsoft 365 work accounts no
# longer do (basic-auth IMAP is retired there; that path needs OAuth/Graph).
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=burner@example.com
IMAP_PASSWORD=your-app-password
IMAP_DRAFTS_FOLDER=Drafts
